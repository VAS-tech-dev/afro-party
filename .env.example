# ---------------------------------------------------------------------------
# Afro-Latina Party — environment variables
# Copy this file to `.env.local` and fill in the values. Never commit .env.local.
# See README.md for where to obtain each value.
# ---------------------------------------------------------------------------

# Public base URL of the deployed site (used for absolute links, OG, tickets).
# Local: http://localhost:3000 — Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (database) ---------------------------------------------------
# Project URL, e.g. https://xxxxxxxx.supabase.co  (this is a URL, NOT a key)
NEXT_PUBLIC_SUPABASE_URL=https://hdolactcfpbtkodzvksf.supabase.co
# Server-side secret key — SERVER ONLY. Never commit. Full DB access.
# New Supabase API keys: use the "secret" key (sb_secret_…). Legacy: service_role.
SUPABASE_SERVICE_ROLE_KEY=

# --- Emails via Gmail (SMTP + App Password) --------------------------------
# The association's Gmail address. Emails are sent from here.
GMAIL_USER=
# A Google "App Password" (16 chars) — requires 2-step verification enabled.
# Create one at https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=
# Optional: override the sender display name/address (defaults to GMAIL_USER).
# EMAIL_FROM=Afro-Latina Party <info.vas.worms@gmail.com>

# --- Admin dashboard auth --------------------------------------------------
ADMIN_EMAIL=
# bcrypt/argon-style hash of the admin password (NOT the plain password).
# Generate with the helper documented in the README.
ADMIN_PASSWORD_HASH=
# Long random string used to sign the admin session cookie (JWT).
# Generate: `openssl rand -base64 32`
AUTH_SECRET=

# --- Payment (manual, no PayPal API) ---------------------------------------
# e.g. https://paypal.me/yourhandle
PAYPAL_LINK=
